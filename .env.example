# ── GI.Setlist — variables de entorno ──────────────────────────────────────
# Copiá este archivo a `.env` (local) y completá los valores. En producción
# (Vercel) cargá estas mismas claves en Project Settings → Environment Variables.
# NUNCA subas el `.env` real al repo.

# ── Supabase (fuente única, compartida con LivePads) ───────────────────────
# La SERVICE_ROLE key es SOLO de backend (se salta RLS) — no la expongas al cliente.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Id de la librería maestra de GI.Setlist dentro de Supabase.
GISETLIST_LIBRARY_ID=

# ── Admin ───────────────────────────────────────────────────────────────────
# Contraseña del modo administrador. OBLIGATORIA: sin ella el login queda
# deshabilitado (falla cerrado, no hay fallback). Usá una contraseña fuerte.
ADMIN_PASSWORD=

# ── Integraciones de IA (acordes + chat asistente) ─────────────────────────
GROQ_API_KEY=
OPENROUTER_API_KEY=

# ── YouTube (opcional: títulos/datos de videos) ────────────────────────────
YOUTUBE_API_KEY=

# ── Servidor local (opcional) ──────────────────────────────────────────────
PORT=5000
